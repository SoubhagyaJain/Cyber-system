# ── CyberSentinel Frontend Environment ────────────────────────────────────────
# Copy this file to .env and customise values as needed.
#
# In Docker (production compose): leave VITE_API_BASE empty.
#   Nginx reverse-proxies /api/* to the backend container automatically.
#
# In Docker (dev compose): set to http://localhost:8000 for direct access.
#
# For cloud deployment (Vercel): set to your Render backend URL.

# API base URL (empty = same origin, nginx proxies /api/*)
VITE_API_BASE=
