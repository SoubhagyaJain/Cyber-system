# ── CyberSentinel Backend Environment ─────────────────────────────────────────
# Copy this file to .env and customise values as needed.

# Thread safety (prevents OpenMP deadlock on multi-threaded sklearn/xgboost)
OMP_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
MKL_NUM_THREADS=1

# Optional: remote dataset server (leave empty to use synthetic data)
DATA_SOURCE_URL=
DATA_SECRET=cybersentinel-local-2024

# Uvicorn
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
